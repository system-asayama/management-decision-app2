# 環境設定
ENV=dev
DEBUG=1
APP_VERSION=0.1.0
TZ=Asia/Tokyo

# アプリケーション設定
APP_NAME=management-decision-app
SECRET_KEY=dev-secret-key-change-in-production

# 認証設定
JWT_SECRET=local-dev-secret-key-change-this
ENABLE_MOCK_AUTH=true

# データベース設定
DATABASE_URL=postgresql://user:password@localhost:5432/management_decision_making

# OAuth設定（本番環境用）
OAUTH_SERVER_URL=https://api.manus.im
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# オーナー情報（モック認証で使用）
OWNER_OPEN_ID=local-dev-user
OWNER_NAME=Local Developer
